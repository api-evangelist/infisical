{
  "title": "Create Secret — Request Example",
  "description": "Create a new secret in a project environment using the v3 raw secrets API.",
  "request": {
    "method": "POST",
    "url": "https://app.infisical.com/api/v3/secrets/raw/DATABASE_URL",
    "headers": {
      "Authorization": "Bearer <access-token>",
      "Content-Type": "application/json"
    },
    "body": {
      "projectSlug": "my-project",
      "environment": "dev",
      "secretPath": "/backend",
      "secretValue": "postgres://user:pass@host:5432/mydb",
      "secretComment": "Primary Postgres connection string for the backend service.",
      "type": "shared"
    }
  },
  "response": {
    "statusCode": 200,
    "body": {
      "secret": {
        "id": "3c90c3cc-0d44-4b50-8888-8dd25736052a",
        "version": 1,
        "workspace": "abc123",
        "type": "shared",
        "environment": "dev",
        "secretKey": "DATABASE_URL",
        "secretValue": "postgres://user:pass@host:5432/mydb",
        "secretComment": "Primary Postgres connection string for the backend service.",
        "createdAt": "2026-06-13T00:00:00.000Z",
        "updatedAt": "2026-06-13T00:00:00.000Z"
      }
    }
  }
}
